#include <app_main.h>
#include <output.h>
#include <pwm.h>

static Output led;
extern TIM_HandleTypeDef htim1;
static PWM pwm;

void App_Init(void)
{
	Output_Init(&led, LED_GPIO_Port, LED_Pin, OUTPUT_ACTIVE_HIGH);
	HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_1);
	HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_2);
	HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_3);

	PWM_Init(&pwm, TIM1, 0, 5000);

}


void App_Loop(void)
{
	PWM_SetCcr(&pwm, 500);
	HAL_Delay(1000);
	PWM_SetCcr(&pwm, 2100);
	HAL_Delay(1000);

}
