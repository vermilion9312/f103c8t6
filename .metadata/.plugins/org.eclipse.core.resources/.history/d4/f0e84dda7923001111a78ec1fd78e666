#include <pwm.h>

void PWM_Init(PWM* this, TIM_TypeDef* tim, uint8_t channerlNumber, uint32_t ccrMin, uint32_t ccrMax)
{
	this->tim      = tim;
	this->ccrMin   = ccrMin;
	this->ccrMax   = ccrMax;

	switch (channerlNumber)
	{
	case 1:
		this->channel = &(this->tim->CCR1);
		break;

	case 2:
		this->channel = &(this->tim->CCR2);
		break;

	case 3:
		this->channel = &(this->tim->CCR3);
		break;

	case 4:
		this->channel = &(this->tim->CCR4);
		break;

	default:
		break;
	}
}
void PWM_SetAngle(PWM* this, uint8_t angle)
{
    if (angle > 180) angle = 180;

    *(this->channel) = this->ccrMin + ((this->ccrMax - this->ccrMin) * angle) / 180;
}

void PWM_SetCcr(PWM* this, uint32_t ccr)
{
	*(this->channel) = ccr;
}
